<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ShowCast.ViewModels"
        xmlns:core="using:ShowCast.Core"
        x:Class="ShowCast.Views.AddEditEventDialog"
        x:DataType="vm:AddEditEventViewModel"
        Width="420"
        SizeToContent="Height"
        CanResize="False"
        Background="#2d2d2d"
        SystemDecorations="BorderOnly"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>

        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#aaaaaa"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="60"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style Selector="TextBox.dark">
            <Setter Property="Background" Value="#3a3a3a"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Foreground" Value="#dddddd"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="CaretBrush" Value="#dddddd"/>
        </Style>

        <Style Selector="ComboBox.dark">
            <Setter Property="Background" Value="#3a3a3a"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Kill the orange Fluent focus ring on all TextBoxes in this window -->
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="Button.spin-btn">
            <Setter Property="Background" Value="#3a3a3a"/>
            <Setter Property="Foreground" Value="#aaaaaa"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.spin-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#505050"/>
        </Style>

        <Style Selector="ToggleButton.day-tog">
            <Setter Property="Background" Value="#3a3a3a"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="ToggleButton.day-tog:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="#1a5096"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ToggleButton.day-tog:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4a4a4a"/>
        </Style>

        <Style Selector="Button.action-btn">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.save-btn">
            <Setter Property="Background" Value="#1a5096"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.save-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#245faa"/>
        </Style>
        <Style Selector="Button.save-btn:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#666666"/>
        </Style>
        <Style Selector="Button.cancel-btn">
            <Setter Property="Background" Value="#3a3a3a"/>
            <Setter Property="Foreground" Value="#cccccc"/>
        </Style>
        <Style Selector="Button.cancel-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4a4a4a"/>
        </Style>

    </Window.Styles>

    <Border BorderBrush="#555555" BorderThickness="1">
        <Grid RowDefinitions="36,*,50">

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#1e1e1e"
                    BorderBrush="#555555" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding Title}"
                               FontSize="13" FontWeight="Bold"
                               Foreground="#e07050"
                               VerticalAlignment="Center"
                               Margin="16,0"/>
                    <Button Grid.Column="1" Content="✕"
                            Click="OnCancel"
                            Background="Transparent" Foreground="#888888"
                            BorderThickness="0" Padding="12,0"
                            FontSize="14" VerticalAlignment="Stretch"/>
                </Grid>
            </Border>

            <!-- Form -->
            <StackPanel Grid.Row="1" Margin="16,14,16,14" Spacing="8">

                <!-- Date -->
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Classes="label" Text="Date"/>
                    <TextBox Grid.Column="1" Classes="dark"
                             Text="{Binding DateText}"
                             Watermark="MM/DD/YYYY"/>
                </Grid>

                <!-- Time -->
                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*">
                    <TextBlock Classes="label" Text="Time"/>

                    <Border Grid.Column="1" Background="#3a3a3a" BorderBrush="#555555"
                            BorderThickness="1" CornerRadius="3" Width="60" Height="28">
                        <Grid ColumnDefinitions="*,18">
                            <TextBlock Text="{Binding HourText}"
                                       Foreground="#dddddd" FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Spacing="0" VerticalAlignment="Center">
                                <Button Classes="spin-btn" Content="▲" Tag="hour-up"   Click="OnSpin"/>
                                <Button Classes="spin-btn" Content="▼" Tag="hour-down" Click="OnSpin"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Column="2" Text=":" FontSize="16" FontWeight="Bold"
                               Foreground="#888888" VerticalAlignment="Center" Margin="4,0"/>

                    <Border Grid.Column="3" Background="#3a3a3a" BorderBrush="#555555"
                            BorderThickness="1" CornerRadius="3" Width="60" Height="28">
                        <Grid ColumnDefinitions="*,18">
                            <TextBlock Text="{Binding MinuteText}"
                                       Foreground="#dddddd" FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Spacing="0" VerticalAlignment="Center">
                                <Button Classes="spin-btn" Content="▲" Tag="min-up"   Click="OnSpin"/>
                                <Button Classes="spin-btn" Content="▼" Tag="min-down" Click="OnSpin"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Repeat -->
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Classes="label" Text="Repeat"/>
                    <ComboBox Grid.Column="1" Classes="dark"
                              ItemsSource="{Binding RepeatTypes}"
                              SelectedItem="{Binding Repeat}"
                              HorizontalAlignment="Left" MinWidth="140"/>
                </Grid>

                <!-- Repeat interval (hidden when None) -->
                <Grid ColumnDefinitions="Auto,Auto,Auto,*"
                      IsVisible="{Binding ShowRepeatOptions}">
                    <TextBlock Classes="label" Text="Every"/>
                    <Border Grid.Column="1" Background="#3a3a3a" BorderBrush="#555555"
                            BorderThickness="1" CornerRadius="3" Width="60" Height="28">
                        <Grid ColumnDefinitions="*,18">
                            <TextBlock Text="{Binding RepeatIntervalText}"
                                       Foreground="#dddddd" FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Spacing="0" VerticalAlignment="Center">
                                <Button Classes="spin-btn" Content="▲" Tag="interval-up"   Click="OnSpin"/>
                                <Button Classes="spin-btn" Content="▼" Tag="interval-down" Click="OnSpin"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Grid.Column="2" Text="{Binding RepeatUnitLabel}"
                               FontSize="11" Foreground="#aaaaaa"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </Grid>

                <!-- Day-of-week toggles (hidden unless Weekly) -->
                <Grid ColumnDefinitions="Auto,*" IsVisible="{Binding ShowWeeklyOptions}">
                    <TextBlock Classes="label" Text="Days"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                        <ToggleButton Classes="day-tog" Content="SU" IsChecked="{Binding RepeatSunday}"/>
                        <ToggleButton Classes="day-tog" Content="MO" IsChecked="{Binding RepeatMonday}"/>
                        <ToggleButton Classes="day-tog" Content="TU" IsChecked="{Binding RepeatTuesday}"/>
                        <ToggleButton Classes="day-tog" Content="WE" IsChecked="{Binding RepeatWednesday}"/>
                        <ToggleButton Classes="day-tog" Content="TH" IsChecked="{Binding RepeatThursday}"/>
                        <ToggleButton Classes="day-tog" Content="FR" IsChecked="{Binding RepeatFriday}"/>
                        <ToggleButton Classes="day-tog" Content="SA" IsChecked="{Binding RepeatSaturday}"/>
                    </StackPanel>
                </Grid>

                <!-- Until (hidden when None) -->
                <Grid ColumnDefinitions="Auto,Auto,*" IsVisible="{Binding ShowRepeatOptions}">
                    <TextBlock Classes="label" Text="Until"/>
                    <CheckBox Grid.Column="1" IsChecked="{Binding HasRepeatUntil}"
                              Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="2" Classes="dark"
                             Text="{Binding RepeatUntilText}"
                             Watermark="MM/DD/YYYY"
                             IsEnabled="{Binding HasRepeatUntil}"/>
                </Grid>

                <!-- Divider -->
                <Border Background="#444444" Height="1" Margin="0,2"/>

                <!-- Rundown -->
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Classes="label" Text="Rundown"/>
                    <ComboBox Grid.Column="1" Classes="dark"
                              ItemsSource="{Binding Rundowns}"
                              SelectedItem="{Binding SelectedRundown}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type core:Rundown}">
                                <TextBlock Text="{Binding Name}" FontSize="11"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <!-- Package -->
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Classes="label" Text="Package"/>
                    <ComboBox Grid.Column="1" Classes="dark"
                              ItemsSource="{Binding RundownPackages}"
                              SelectedItem="{Binding SelectedPackage}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type core:Package}">
                                <TextBlock Text="{Binding Name}" FontSize="11"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <!-- Page -->
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Classes="label" Text="Page"/>
                    <ComboBox Grid.Column="1" Classes="dark"
                              ItemsSource="{Binding PackagePages}"
                              SelectedItem="{Binding SelectedPage}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type core:Page}">
                                <TextBlock Text="{Binding Name}" FontSize="11"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <!-- Label -->
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Classes="label" Text="Label"/>
                    <TextBox Grid.Column="1" Classes="dark"
                             Text="{Binding Label}"
                             Watermark="(optional — defaults to package name)"/>
                </Grid>

                <!-- Divider -->
                <Border Background="#444444" Height="1" Margin="0,2"
                        IsVisible="{Binding HasAvailableTimers}"/>

                <!-- Timer Actions header -->
                <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding HasAvailableTimers}">
                    <TextBlock Text="TIMER ACTIONS"
                               FontSize="10" FontWeight="Bold"
                               Foreground="#888888" VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="+ Add"
                            Click="OnAddTimerAction"
                            Background="#3a3a3a" Foreground="#aaaaaa"
                            BorderThickness="0" CornerRadius="3"
                            FontSize="10" Height="22" Padding="8,0"/>
                </Grid>

                <!-- Timer action rows -->
                <ItemsControl ItemsSource="{Binding TimerActionRows}"
                              IsVisible="{Binding HasAvailableTimers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:TimerActionRow">
                            <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,2,0,0">
                                <ComboBox Grid.Column="0" Classes="dark"
                                          ItemsSource="{Binding AvailableTimers}"
                                          SelectedItem="{Binding SelectedTimer}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate DataType="core:TimerDef">
                                            <TextBlock Text="{Binding Name}" FontSize="11"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <ComboBox Grid.Column="1" Classes="dark"
                                          ItemsSource="{Binding AvailableActions}"
                                          SelectedItem="{Binding Action}"
                                          Width="100" Margin="4,0,0,0"/>
                                <Button Grid.Column="2"
                                        Content="✕"
                                        Tag="{Binding}"
                                        Click="OnRemoveTimerAction"
                                        Background="Transparent" Foreground="#888888"
                                        BorderThickness="0" Width="24" Height="28"
                                        FontSize="11" Padding="0" Margin="4,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#1e1e1e"
                    BorderBrush="#555555" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="8" Margin="0,0,16,0">
                    <Button Classes="action-btn cancel-btn" Content="Cancel" Click="OnCancel"/>
                    <Button Classes="action-btn save-btn"
                            Content="Save"
                            IsEnabled="{Binding CanSave}"
                            Click="OnSave"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>

</Window>
