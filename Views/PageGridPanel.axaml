<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ShowCast.ViewModels"
             x:Class="ShowCast.Views.PageGridPanel">

    <UserControl.Styles>

        <!-- Strip ListBoxItem default selection highlight -->
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="5"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <!-- Selection driven by ListBox native state (synchronous, fixes first-right-click delay) -->
        <Style Selector="ListBoxItem:selected Border.page-card">
            <Setter Property="BorderBrush" Value="#3b82f6"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.page-card.live">
            <Setter Property="BorderBrush" Value="#cc3333"/>
        </Style>

        <!-- Page card default -->
        <Style Selector="Border.page-card">
            <Setter Property="Background" Value="#3a3a3a"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <!-- Selected: blue border -->
        <Style Selector="Border.page-card.selected">
            <Setter Property="BorderBrush" Value="#3b82f6"/>
        </Style>
        <!-- Live: red border -->
        <Style Selector="Border.page-card.live">
            <Setter Property="BorderBrush" Value="#cc3333"/>
        </Style>
        <!-- Selected + Live: red wins -->
        <Style Selector="Border.page-card.selected.live">
            <Setter Property="BorderBrush" Value="#cc3333"/>
        </Style>

    </UserControl.Styles>

    <DockPanel>

        <!-- ── Flat page grid (show mode) ── -->
        <ScrollViewer IsVisible="{Binding ShowingFlatGrid}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Background="#2d2d2d">
            <ListBox x:Name="PageList"
                     ItemsSource="{Binding Pages}"
                     SelectedItem="{Binding SelectedPage}"
                     Background="Transparent"
                     Padding="6"
                     Tapped="OnPageTapped"
                     KeyDown="OnPageKeyDown"
                     ContextRequested="OnPageContextRequested"
                     PointerPressed="OnPageListPointerPressed"
                     PointerMoved="OnPageListPointerMoved"
                     PointerReleased="OnPageListPointerReleased"
                     DragDrop.AllowDrop="True">

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:PageViewModel}">
                        <Panel>
                            <!-- Page card -->
                            <Border Classes="page-card"
                                    Classes.selected="{Binding IsSelected}"
                                    Classes.live="{Binding IsLive}"
                                    Margin="4"
                                    Width="{Binding $parent[UserControl].DataContext.ThumbSize}">
                                <StackPanel>

                                    <!-- Thumbnail + live badge overlay -->
                                    <Grid>
                                        <Image Source="{Binding Thumbnail}"
                                               Height="{Binding $parent[UserControl].DataContext.ThumbHeight}"
                                               Stretch="Fill"
                                               RenderOptions.BitmapInterpolationMode="MediumQuality"/>

                                        <!-- LIVE badge (top-left) -->
                                        <Border Background="#cc3333" CornerRadius="3"
                                                Padding="4,2" Margin="5"
                                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                                IsVisible="{Binding IsLive}">
                                            <TextBlock Text="LIVE" FontSize="8" FontWeight="Bold"
                                                       Foreground="White"/>
                                        </Border>

                                        <!-- Timer badge (bottom-right) -->
                                        <Border Background="#bb000000" CornerRadius="3"
                                                Padding="4,2" Margin="5"
                                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                IsVisible="{Binding HasTimer}">
                                            <StackPanel Orientation="Horizontal" Spacing="2">
                                                <TextBlock Text="⏱" FontSize="8" Foreground="#dddddd"/>
                                                <TextBlock Text="{Binding TimerLabel}" FontSize="8"
                                                           FontWeight="Bold" Foreground="#dddddd"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Page name -->
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="11" Foreground="White"
                                               TextTrimming="CharacterEllipsis"
                                               Padding="5,3,5,4"/>

                                </StackPanel>
                            </Border>

                            <!-- Insert-before indicator: vertical line at left edge -->
                            <Border Width="3" VerticalAlignment="Stretch"
                                    HorizontalAlignment="Left"
                                    Margin="2,8,0,8"
                                    Background="#5599ff" CornerRadius="2"
                                    IsHitTestVisible="False"
                                    IsVisible="{Binding ShowInsertBefore}"/>

                            <!-- Insert-after indicator: vertical line at right edge (for appending after last) -->
                            <Border Width="3" VerticalAlignment="Stretch"
                                    HorizontalAlignment="Right"
                                    Margin="0,8,2,8"
                                    Background="#5599ff" CornerRadius="2"
                                    IsHitTestVisible="False"
                                    IsVisible="{Binding ShowInsertAfter}"/>
                        </Panel>
                    </DataTemplate>
                </ListBox.ItemTemplate>

            </ListBox>
        </ScrollViewer>

        <!-- ── Grouped page view (rundown mode) ── -->
        <ScrollViewer x:Name="GroupedView"
                      IsVisible="{Binding ShowingRundown}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Background="#2d2d2d"
                      Tapped="OnGroupedPageTapped"
                      ContextRequested="OnGroupedPageContextRequested"
                      PointerPressed="OnGroupedViewPointerPressed"
                      PointerMoved="OnGroupedViewPointerMoved"
                      PointerReleased="OnGroupedViewPointerReleased"
                      DragDrop.AllowDrop="True">
            <ItemsControl ItemsSource="{Binding PageGroups}" Background="Transparent" Padding="6">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:PageGroupViewModel}">
                        <StackPanel Margin="0,0,0,8">

                            <!-- Package header with output selector + controls -->
                            <Border Background="#252525" CornerRadius="4"
                                    Padding="6,3" Margin="4,6,4,2">
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="#aaaaaa"
                                               VerticalAlignment="Center"
                                               Margin="2,0,8,0"/>

                                    <!-- Add page button -->
                                    <Button Grid.Column="1"
                                            Tag="add-page"
                                            Content="+ Page"
                                            Padding="8,4"
                                            FontSize="11" FontWeight="Bold"
                                            Foreground="#cccccc"
                                            BorderThickness="0" CornerRadius="3"
                                            VerticalContentAlignment="Center"
                                            Margin="0,0,4,0">
                                        <Button.Styles>
                                            <Style Selector="Button">
                                                <Setter Property="Background" Value="#2a4a2a"/>
                                            </Style>
                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="#3a6a3a"/>
                                            </Style>
                                        </Button.Styles>
                                    </Button>

                                    <!-- Edit package button -->
                                    <Button Grid.Column="2"
                                            Tag="edit-package"
                                            Content="Edit"
                                            Padding="8,4"
                                            FontSize="11" FontWeight="Bold"
                                            Foreground="#cccccc"
                                            BorderThickness="0" CornerRadius="3"
                                            VerticalContentAlignment="Center"
                                            Margin="0,0,4,0">
                                        <Button.Styles>
                                            <Style Selector="Button">
                                                <Setter Property="Background" Value="#1a3a5a"/>
                                            </Style>
                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="#2a5a8a"/>
                                            </Style>
                                        </Button.Styles>
                                    </Button>

                                    <!-- Output picker button -->
                                    <Button Grid.Column="3"
                                            Content="{Binding SelectedOutput.Name, FallbackValue='Output'}"
                                            MinWidth="70"
                                            Padding="8,4"
                                            FontSize="11" FontWeight="Bold"
                                            Foreground="#cccccc"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            VerticalContentAlignment="Center"
                                            Margin="4,0,0,0">
                                        <Button.Styles>
                                            <Style Selector="Button">
                                                <Setter Property="Background" Value="#2d2d2d"/>
                                                <Setter Property="BorderBrush" Value="#555555"/>
                                            </Style>
                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="#3a3a3a"/>
                                            </Style>
                                        </Button.Styles>
                                        <Button.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedLeft">
                                                <Border Background="#1c1c1c"
                                                        BorderBrush="#555555"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="10,8">
                                                    <StackPanel Spacing="6" MinWidth="160">

                                                        <TextBlock Text="OUTPUT"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   Foreground="#666666"/>

                                                        <ListBox ItemsSource="{Binding OutputStates}"
                                                                 SelectedItem="{Binding SelectedOutput}"
                                                                 Background="Transparent"
                                                                 Padding="0">
                                                            <ListBox.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel/>
                                                                </ItemsPanelTemplate>
                                                            </ListBox.ItemsPanel>
                                                            <ListBox.Styles>
                                                                <Style Selector="ListBoxItem">
                                                                    <Setter Property="Padding" Value="8,4"/>
                                                                    <Setter Property="Margin" Value="2"/>
                                                                    <Setter Property="Background" Value="#2d2d2d"/>
                                                                    <Setter Property="CornerRadius" Value="3"/>
                                                                    <Setter Property="Foreground" Value="#cccccc"/>
                                                                    <Setter Property="FontSize" Value="11"/>
                                                                    <Setter Property="Cursor" Value="Hand"/>
                                                                </Style>
                                                                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                                                    <Setter Property="Background" Value="#1a5096"/>
                                                                </Style>
                                                                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                                                    <Setter Property="Background" Value="#3a3a3a"/>
                                                                </Style>
                                                            </ListBox.Styles>
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Name}" FontSize="11"/>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>

                                                    </StackPanel>
                                                </Border>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>

                                    <!-- Transition picker button -->
                                    <Button Grid.Column="4"
                                            Content="{Binding TransitionLabel}"
                                            MinWidth="70"
                                            Padding="8,4"
                                            FontSize="11" FontWeight="Bold"
                                            Foreground="#cccccc"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            VerticalContentAlignment="Center"
                                            Margin="4,0,0,0">
                                        <Button.Styles>
                                            <Style Selector="Button">
                                                <Setter Property="Background" Value="#2d2d2d"/>
                                                <Setter Property="BorderBrush" Value="#555555"/>
                                            </Style>
                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="#3a3a3a"/>
                                            </Style>
                                        </Button.Styles>
                                        <Button.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedLeft">
                                                <Border Background="#1c1c1c"
                                                        BorderBrush="#555555"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="10,8">
                                                    <StackPanel Spacing="6" MinWidth="180">

                                                        <TextBlock Text="TYPE"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   Foreground="#666666"/>

                                                        <ListBox ItemsSource="{Binding TransitionTypes}"
                                                                 SelectedItem="{Binding DefaultTransitionType}"
                                                                 Background="Transparent"
                                                                 Padding="0">
                                                            <ListBox.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel/>
                                                                </ItemsPanelTemplate>
                                                            </ListBox.ItemsPanel>
                                                            <ListBox.Styles>
                                                                <Style Selector="ListBoxItem">
                                                                    <Setter Property="Padding" Value="8,4"/>
                                                                    <Setter Property="Margin" Value="2"/>
                                                                    <Setter Property="Background" Value="#2d2d2d"/>
                                                                    <Setter Property="CornerRadius" Value="3"/>
                                                                    <Setter Property="Foreground" Value="#cccccc"/>
                                                                    <Setter Property="FontSize" Value="11"/>
                                                                    <Setter Property="Cursor" Value="Hand"/>
                                                                </Style>
                                                                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                                                    <Setter Property="Background" Value="#1a5096"/>
                                                                </Style>
                                                                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                                                    <Setter Property="Background" Value="#3a3a3a"/>
                                                                </Style>
                                                            </ListBox.Styles>
                                                        </ListBox>

                                                        <Border Height="1" Background="#333333" Margin="0,2"/>

                                                        <TextBlock Text="DURATION"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   Foreground="#666666"/>

                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <NumericUpDown Grid.Column="0"
                                                                           Value="{Binding DefaultTransitionDuration}"
                                                                           Minimum="0" Maximum="10000"
                                                                           Increment="50"
                                                                           FormatString="0"
                                                                           Height="24"
                                                                           FontSize="11"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text=" ms"
                                                                       FontSize="11" Foreground="#888888"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>

                                                    </StackPanel>
                                                </Border>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>

                                    <!-- Active (output window) toggle — hidden for NDI outputs -->
                                    <Button Grid.Column="5"
                                            Tag="active"
                                            Content="OUTPUT"
                                            IsVisible="{Binding SelectedOutput.IsDisplayType}"
                                            Classes.active="{Binding SelectedOutput.IsOutputWindowOpen}"
                                            Padding="8,4"
                                            FontSize="11" FontWeight="Bold"
                                            Foreground="White"
                                            BorderThickness="0" CornerRadius="3"
                                            VerticalContentAlignment="Center"
                                            Margin="4,0,0,0">
                                        <Button.Styles>
                                            <Style Selector="Button">
                                                <Setter Property="Background" Value="#444444"/>
                                            </Style>
                                            <Style Selector="Button.active">
                                                <Setter Property="Background" Value="#cc2222"/>
                                            </Style>
                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="#555555"/>
                                            </Style>
                                            <Style Selector="Button.active:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="#aa1111"/>
                                            </Style>
                                        </Button.Styles>
                                    </Button>

                                    <!-- Clear -->
                                    <Button Grid.Column="6"
                                            Tag="clear"
                                            Content="CLEAR"
                                            Padding="8,4"
                                            FontSize="11" FontWeight="Bold"
                                            Foreground="White"
                                            BorderThickness="0" CornerRadius="3"
                                            VerticalContentAlignment="Center"
                                            Margin="4,0,0,0">
                                        <Button.Styles>
                                            <Style Selector="Button">
                                                <Setter Property="Background" Value="#444444"/>
                                            </Style>
                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="#555555"/>
                                            </Style>
                                        </Button.Styles>
                                    </Button>

                                </Grid>
                            </Border>

                            <!-- Pages in this package -->
                            <ItemsControl ItemsSource="{Binding Pages}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:PageViewModel}">
                                        <Panel>
                                            <Border Classes="page-card"
                                                    Classes.selected="{Binding IsSelected}"
                                                    Classes.live="{Binding IsLive}"
                                                    Margin="4"
                                                    Width="{Binding $parent[UserControl].DataContext.ThumbSize}">
                                                <StackPanel>
                                                    <Grid>
                                                        <Image Source="{Binding Thumbnail}"
                                                               Height="{Binding $parent[UserControl].DataContext.ThumbHeight}"
                                                               Stretch="Fill"
                                                               RenderOptions.BitmapInterpolationMode="MediumQuality"/>
                                                        <Border Background="#cc3333" CornerRadius="3"
                                                                Padding="4,2" Margin="5"
                                                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                                                IsVisible="{Binding IsLive}">
                                                            <TextBlock Text="LIVE" FontSize="8" FontWeight="Bold"
                                                                       Foreground="White"/>
                                                        </Border>
                                                        <Border Background="#bb000000" CornerRadius="3"
                                                                Padding="4,2" Margin="5"
                                                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                                IsVisible="{Binding HasTimer}">
                                                            <StackPanel Orientation="Horizontal" Spacing="2">
                                                                <TextBlock Text="⏱" FontSize="8" Foreground="#dddddd"/>
                                                                <TextBlock Text="{Binding TimerLabel}" FontSize="8"
                                                                           FontWeight="Bold" Foreground="#dddddd"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="11" Foreground="White"
                                                               TextTrimming="CharacterEllipsis"
                                                               Padding="5,3,5,4"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Insert-before indicator -->
                                            <Border Width="3" VerticalAlignment="Stretch"
                                                    HorizontalAlignment="Left"
                                                    Margin="2,8,0,8"
                                                    Background="#5599ff" CornerRadius="2"
                                                    IsHitTestVisible="False"
                                                    IsVisible="{Binding ShowInsertBefore}"/>

                                            <!-- Insert-after indicator -->
                                            <Border Width="3" VerticalAlignment="Stretch"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,8,2,8"
                                                    Background="#5599ff" CornerRadius="2"
                                                    IsHitTestVisible="False"
                                                    IsVisible="{Binding ShowInsertAfter}"/>
                                        </Panel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</UserControl>
