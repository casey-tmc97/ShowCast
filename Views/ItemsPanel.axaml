<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ShowCast.Views.ItemsPanel">

    <DockPanel LastChildFill="True">

        <Border DockPanel.Dock="Top" Classes="panel-header">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="PACKAGES"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ItemsHeader, FallbackValue=''}"
                           FontSize="11" Foreground="#888888" FontWeight="Normal"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                           Margin="6,0,0,0"/>
                <Button Grid.Column="2"
                        Content="+" Width="22" Height="20" Padding="0"
                        FontSize="14" FontWeight="Bold"
                        Background="Transparent" Foreground="#888888"
                        BorderThickness="0" CornerRadius="3"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        IsVisible="{Binding ShowingLibrary}"
                        Click="OnAddShow">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#3a3a3a"/>
                        </Style>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </Grid>
        </Border>

        <ListBox x:Name="ItemList"
                 ItemsSource="{Binding ShowItems}"
                 SelectedIndex="{Binding SelectedShowItemIndex}"
                 SelectionChanged="OnItemSelected"
                 Background="Transparent" Padding="4"
                 ContextRequested="OnContextRequested"
                 DragDrop.AllowDrop="True">
            <ListBox.Styles>
                <Style Selector="ListBoxItem.page-drop-target">
                    <Setter Property="Background" Value="#1a5096"/>
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" FontSize="13"
                               Foreground="White" Padding="4,3"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </DockPanel>
</UserControl>
